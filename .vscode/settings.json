{
  "remote.WSL.fileWatcher.polling": true,
  "remote.WSL.fileWatcher.pollingInterval": 2500,

  "eslint.enable": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "prettier.requireConfig": true,
  "prettier.endOfLine": "auto",

  "editor.fontLigatures": true,
  "typescript.validate.enable": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "files.trimFinalNewlines": true,

  "telemetry.telemetryLevel": "off",
  "telemetry.enableTelemetry": false,
  "redhat.telemetry.enabled": false,
  "terminal.integrated.fontFamily": "monospace, PowerlineSymbols, 'MesloLGS NF'",
  "jest.debugMode": true,
  "explorer.compactFolders": false,
  "workbench.editor.showTabs": "multiple",
  "explorer.confirmDelete": false,
  "gitlens.gitCommands.skipConfirmations": ["fetch:command", "switch:command", "stash-push:command"],
  "workbench.editor.highlightModifiedTabs": true,
  "editor.fontSize": 15,
  "git.suggestSmartCommit": false,
  "workbench.iconTheme": "material-icon-theme",
  "editor.renderLineHighlight": "gutter",
  "material-icon-theme.folders.associations": {
    "infra": "app",
    "entities": "class",
    "schemas": "class",
    "typeorm": "database",
    "repositories": "mappings",
    "http": "container",
    "migrations": "tools",
    "module": "components",
    "implementations": "core",
    "dtos": "typescript",
    "fakes": "mock",
    "websockets": "pipe",
    "protos": "pipe",
    "grpc": "pipe"
  },
  "material-icon-theme.files.associations": {
    "ormconfig.json": "database",
    "tsconfig.json": "tune",
    "*.proto": "3d"
  },
  "git.confirmSync": false,
  "explorer.fileNesting.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "bddFeatureEditor.language": "pt"
}
